{
  "name": "@auth/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "reset-password": "tsx scripts/reset-password.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "latest",
    "@better-auth/oauth-provider": "latest",
    "@hono/node-server": "latest",
    "better-auth": "latest",
    "dotenv": "latest",
    "drizzle-orm": "latest",
    "hono": "latest",
    "nanoid": "latest",
    "pg": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "latest",
    "drizzle-kit": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
